#!/usr/bin/env python3
"""
Transformer-based Text-to-Gloss Translation Training Script
Usage:
    python train_transformer_aslg.py --epochs 120 --batch_size 32
    python train_transformer_aslg.py --resume_from checkpoints/best_model.pt
    python train_transformer_aslg.py --evaluate_only
"""

import argparse, json, math, os, re, string
from collections import Counter
from pathlib import Path
import pandas as pd
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader
from torch.nn.utils.rnn import pad_sequence
from sklearn.model_selection import train_test_split
from tqdm.auto import tqdm
import matplotlib.pyplot as plt

try:
    from nltk.translate.bleu_score import corpus_bleu, SmoothingFunction
    from rouge_score import rouge_scorer
    EVAL_AVAILABLE = True
except ImportError:
    EVAL_AVAILABLE = False

# ==================== Data Preprocessing ====================
def remove_noise(txt):
    txt = re.sub(r'\d+', '', txt)
    txt = txt.translate(str.maketrans('', '', string.punctuation))
    return " ".join(txt.split())

def preprocess_text(text): return remove_noise(text.lower())
def preprocess_gloss(gloss): return remove_noise(gloss.upper())

def load_and_preprocess_data(dataset_path):
    print(f"Loading dataset from: {dataset_path}")
    df = pd.read_parquet(dataset_path)
    print(f"Dataset size: {len(df)} samples")
    df['processed_text'] = df['text'].apply(preprocess_text)
    df['processed_gloss'] = df['gloss'].apply(preprocess_gloss)
    return df

def build_vocabularies(df):
    text_counts = Counter()
    for s in df['processed_text']: text_counts.update(s.split())
    text_vocab = ["<pad>", "<unk>"] + sorted(text_counts.keys())
    text_w2i = {t: i for i, t in enumerate(text_vocab)}
    text_i2w = {i: t for i, t in enumerate(text_vocab)}

    gloss_counts = Counter()
    for s in df['processed_gloss']: gloss_counts.update(s.split())
    gloss_vocab = ["<pad>", "<unk>", "<start>", "<end>"] + sorted(gloss_counts.keys())
    gloss_w2i = {t: i for i, t in enumerate(gloss_vocab)}
    gloss_i2w = {i: t for i, t in enumerate(gloss_vocab)}

    print(f"Text Vocab: {len(text_vocab)}, Gloss Vocab: {len(gloss_vocab)}")
    return text_vocab, text_w2i, text_i2w, gloss_vocab, gloss_w2i, gloss_i2w

def tokenize_dataset(df, text_w2i, gloss_w2i):
    df['tokenized_text'] = df['processed_text'].apply(
        lambda x: [text_w2i.get(t, text_w2i["<unk>"]) for t in x.split()])
    df['tokenized_gloss'] = df['processed_gloss'].apply(
        lambda x: [gloss_w2i["<start>"]] + [gloss_w2i.get(t, gloss_w2i["<unk>"]) for t in x.split()] + [gloss_w2i["<end>"]])
    return df

# ==================== Dataset ====================
class TranslationDataset(Dataset):
    def __init__(self, df):
        self.data = df
    def __len__(self): return len(self.data)
    def __getitem__(self, idx):
        return (torch.tensor(self.data.iloc[idx]['tokenized_text'], dtype=torch.long),
                torch.tensor(self.data.iloc[idx]['tokenized_gloss'], dtype=torch.long))

def create_collate_fn(text_pad, gloss_pad):
    def collate_fn(batch):
        text = pad_sequence([b[0] for b in batch], batch_first=True, padding_value=text_pad)
        gloss = pad_sequence([b[1] for b in batch], batch_first=True, padding_value=gloss_pad)
        return text, gloss
    return collate_fn

# ==================== Model ====================
class PositionalEncoding(nn.Module):
    def __init__(self, d_model, dropout=0.1, max_len=4096):
        super().__init__()
        self.dropout = nn.Dropout(dropout)
        pe = torch.zeros(max_len, d_model)
        pos = torch.arange(max_len).unsqueeze(1).float()
        div = torch.exp(torch.arange(0, d_model, 2).float() * (-math.log(10000.0) / d_model))
        pe[:, 0::2], pe[:, 1::2] = torch.sin(pos * div), torch.cos(pos * div)
        self.register_buffer('pe', pe.unsqueeze(0))
    def forward(self, x): return self.dropout(x + self.pe[:, :x.size(1)])

class TransformerModel(nn.Module):
    def __init__(self, text_vs, gloss_vs, emb_dim, nhead, enc_layers, dec_layers, dropout, max_len, pad_idx):
        super().__init__()
        self.pad_idx = pad_idx
        self.text_emb = nn.Embedding(text_vs, emb_dim)
        self.gloss_emb = nn.Embedding(gloss_vs, emb_dim)
        self.pos_enc = PositionalEncoding(emb_dim, dropout, max_len)
        self.transformer = nn.Transformer(emb_dim, nhead, enc_layers, dec_layers, dropout=dropout, batch_first=True)
        self.fc = nn.Linear(emb_dim, gloss_vs)

    def generate_mask(self, sz):
        mask = torch.triu(torch.ones(sz, sz), 1).bool()
        return mask.float().masked_fill(mask, float('-inf'))

    def forward(self, src, tgt):
        src_mask = (src == self.pad_idx)
        tgt_in = tgt[:, :-1]
        tgt_mask = (tgt_in == self.pad_idx)
        causal = self.generate_mask(tgt_in.size(1)).to(tgt.device)
        src_emb = self.pos_enc(self.text_emb(src))
        tgt_emb = self.pos_enc(self.gloss_emb(tgt_in))
        out = self.transformer(src_emb, tgt_emb, tgt_mask=causal, src_key_padding_mask=src_mask,
                               tgt_key_padding_mask=tgt_mask, memory_key_padding_mask=src_mask)
        return self.fc(out)

# ==================== Training Components ====================
class NoamLR:
    def __init__(self, opt, d_model, warmup=4000, factor=1.0):
        self.opt, self.d_model, self.warmup, self.factor = opt, d_model, warmup, factor
        self._step, self._rate = 0, 0
    def state_dict(self): return {'step': self._step, 'rate': self._rate}
    def load_state_dict(self, d): self._step, self._rate = d['step'], d['rate']
    def step(self):
        self._step += 1
        self._rate = self.factor * (self.d_model ** -0.5) * min(self._step ** -0.5, self._step * self.warmup ** -1.5)
        for p in self.opt.param_groups: p['lr'] = self._rate

class LabelSmoothing(nn.Module):
    def __init__(self, smoothing=0.1, ignore_idx=0):
        super().__init__()
        self.smoothing, self.confidence, self.ignore_idx = smoothing, 1 - smoothing, ignore_idx
    def forward(self, pred, target):
        pred = pred.log_softmax(-1)
        with torch.no_grad():
            dist = torch.zeros_like(pred).fill_(self.smoothing / (pred.size(-1) - 2))
            dist.scatter_(1, target.unsqueeze(1), self.confidence)
            mask = (target != self.ignore_idx).float()
            dist *= mask.unsqueeze(-1)
        return -torch.sum(dist * pred) / mask.sum()

class Metrics:
    def __init__(self):
        self.train_losses, self.val_losses, self.lrs = [], [], []
        self.best_val, self.patience_count = float('inf'), 0
    def update(self, tl, vl, lr): self.train_losses.append(tl); self.val_losses.append(vl); self.lrs.append(lr)
    def is_best(self, vl):
        if vl < self.best_val: self.best_val, self.patience_count = vl, 0; return True
        self.patience_count += 1; return False
    def should_stop(self, patience): return self.patience_count >= patience
    def plot(self, path):
        plt.figure(figsize=(12, 4))
        plt.subplot(1,2,1); plt.plot(self.train_losses, label='Train'); plt.plot(self.val_losses, label='Val')
        plt.legend(); plt.title('Loss'); plt.grid(True)
        plt.subplot(1,2,2); plt.plot(self.lrs); plt.title('LR'); plt.grid(True)
        plt.tight_layout(); plt.savefig(path); plt.close()

# ==================== Checkpoint ====================
def save_ckpt(model, opt, sched, metrics, cfg, epoch, path, vocab=None, best=False):
    torch.save({'epoch': epoch, 'model': model.state_dict(), 'opt': opt.state_dict(),
                'sched': sched.state_dict(), 'metrics': (metrics.train_losses, metrics.val_losses, metrics.lrs, metrics.best_val),
                'config': cfg}, path)
    print(f"{'Best model' if best else 'Checkpoint'} saved: {path}")
    if vocab:
        vp = Path(path).parent / 'vocab.json'
        if not vp.exists():
            with open(vp, 'w') as f: json.dump(vocab, f)

def load_ckpt(path, model, opt=None, sched=None):
    ckpt = torch.load(path, map_location='cpu')
    model.load_state_dict(ckpt['model'])
    if opt: opt.load_state_dict(ckpt['opt'])
    if sched: sched.load_state_dict(ckpt['sched'])
    m = Metrics()
    m.train_losses, m.val_losses, m.lrs, m.best_val = ckpt['metrics']
    print(f"Loaded checkpoint epoch {ckpt['epoch']+1}")
    return ckpt['epoch'], ckpt['config'], m

# ==================== Train/Eval ====================
def train_epoch(model, loader, opt, sched, loss_fn, device, accum=1):
    model.train(); total = 0; opt.zero_grad()
    for i, (src, tgt) in enumerate(tqdm(loader, desc='Train')):
        src, tgt = src.to(device), tgt.to(device)
        out = model(src, tgt)
        loss = loss_fn(out.reshape(-1, out.size(-1)), tgt[:, 1:].reshape(-1)) / accum
        loss.backward()
        if (i+1) % accum == 0:
            torch.nn.utils.clip_grad_value_(model.parameters(), 1.0)
            opt.step(); sched.step(); opt.zero_grad()
        total += loss.item() * accum
    return total / len(loader)

def evaluate(model, loader, loss_fn, device):
    model.eval(); total = 0
    with torch.no_grad():
        for src, tgt in tqdm(loader, desc='Eval'):
            src, tgt = src.to(device), tgt.to(device)
            out = model(src, tgt)
            total += loss_fn(out.reshape(-1, out.size(-1)), tgt[:, 1:].reshape(-1)).item()
    return total / len(loader)

def train(model, train_ld, val_ld, opt, sched, loss_fn, device, cfg, ckpt_dir, vocab):
    metrics = Metrics(); start = 0
    ckpt_dir = Path(ckpt_dir); ckpt_dir.mkdir(exist_ok=True, parents=True)
    if cfg['resume_from']:
        start, _, metrics = load_ckpt(cfg['resume_from'], model, opt, sched); start += 1

    for ep in range(start, cfg['epochs']):
        print(f"\n{'='*50}\nEpoch {ep+1}/{cfg['epochs']}\n{'='*50}")
        tl = train_epoch(model, train_ld, opt, sched, loss_fn, device, cfg['accumulation_steps'])
        vl = evaluate(model, val_ld, loss_fn, device)
        metrics.update(tl, vl, sched._rate)
        print(f"Train: {tl:.4f}, Val: {vl:.4f}, LR: {sched._rate:.2e}")

        if (ep+1) % cfg['save_every'] == 0:
            save_ckpt(model, opt, sched, metrics, cfg, ep, ckpt_dir/f'ckpt_{ep+1}.pt', vocab)
        if metrics.is_best(vl):
            save_ckpt(model, opt, sched, metrics, cfg, ep, ckpt_dir/'best_model.pt', vocab, True)
        if cfg['early_stop'] > 0 and metrics.should_stop(cfg['early_stop']):
            print("Early stopping!"); break
        if (ep+1) % 5 == 0: metrics.plot(ckpt_dir/'metrics.png')
    metrics.plot(ckpt_dir/'metrics_final.png')
    return metrics

# ==================== Inference ====================
def translate(model, src, pad_idx, start_idx, end_idx, i2w, device, max_len=100):
    model.eval()
    with torch.no_grad():
        src = src.to(device).unsqueeze(0)
        src_mask = (src == pad_idx)
        mem = model.transformer.encoder(model.pos_enc(model.text_emb(src)), src_key_padding_mask=src_mask)
        ys = torch.tensor([[start_idx]], device=device)
        for _ in range(max_len):
            causal = model.generate_mask(ys.size(1)).to(device)
            out = model.transformer.decoder(model.pos_enc(model.gloss_emb(ys)), mem, tgt_mask=causal, memory_key_padding_mask=src_mask)
            next_tok = model.fc(out[:, -1]).argmax(-1).item()
            if next_tok == end_idx: break
            ys = torch.cat([ys, torch.tensor([[next_tok]], device=device)], 1)
        return " ".join([i2w[i.item()] for i in ys[0, 1:] if i2w[i.item()] != "<end>"])

def eval_bleu_rouge(model, loader, pad, start, end, ti2w, gi2w, device, n=100):
    if not EVAL_AVAILABLE: print("Install nltk/rouge_score"); return
    scorer = rouge_scorer.RougeScorer(['rouge1','rouge2','rougeL'], use_stemmer=True)
    refs, hyps = [], []
    for src_b, tgt_b in tqdm(loader):
        if len(hyps) >= n: break
        for j in range(len(src_b)):
            if len(hyps) >= n: break
            pred = translate(model, src_b[j], pad, start, end, gi2w, device)
            ref = " ".join([gi2w[i.item()] for i in tgt_b[j] if gi2w[i.item()] not in ["<start>","<end>","<pad>"]])
            hyps.append(pred.split()); refs.append([ref.split()])
    bleu = corpus_bleu(refs, hyps, smoothing_function=SmoothingFunction().method1)
    rouge = {k: sum(scorer.score(" ".join(h), " ".join(r[0]))[k].fmeasure for h,r in zip(hyps,refs))/len(hyps) for k in ['rouge1','rouge2','rougeL']}
    print(f"\nBLEU: {bleu:.4f}, ROUGE-1: {rouge['rouge1']:.4f}, ROUGE-2: {rouge['rouge2']:.4f}, ROUGE-L: {rouge['rougeL']:.4f}")

# ==================== Main ====================
def main():
    p = argparse.ArgumentParser()
    p.add_argument('--dataset_path', default='hf://datasets/achrafothman/aslg_pc12/data/train-00000-of-00001.parquet')
    p.add_argument('--train_size', type=int, default=82710)
    p.add_argument('--val_size', type=int, default=4000)
    p.add_argument('--embedding_dim', type=int, default=512)
    p.add_argument('--nhead', type=int, default=8)
    p.add_argument('--num_encoder_layers', type=int, default=3)
    p.add_argument('--num_decoder_layers', type=int, default=3)
    p.add_argument('--dropout', type=float, default=0.1)
    p.add_argument('--max_len', type=int, default=512)
    p.add_argument('--batch_size', type=int, default=32)
    p.add_argument('--accumulation_steps', type=int, default=64)
    p.add_argument('--epochs', type=int, default=120)
    p.add_argument('--warmup_steps', type=int, default=4000)
    p.add_argument('--lr_factor', type=float, default=2.0)
    p.add_argument('--label_smoothing', type=float, default=0.1)
    p.add_argument('--checkpoint_dir', default='checkpoints')
    p.add_argument('--save_every', type=int, default=10)
    p.add_argument('--resume_from', default=None)
    p.add_argument('--early_stop', type=int, default=0)
    p.add_argument('--seed', type=int, default=42)
    p.add_argument('--evaluate_only', action='store_true')
    args = p.parse_args()

    torch.manual_seed(args.seed)
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Device: {device}")

    df = load_and_preprocess_data(args.dataset_path)
    text_vocab, tw2i, ti2w, gloss_vocab, gw2i, gi2w = build_vocabularies(df)
    df = tokenize_dataset(df, tw2i, gw2i)

    train_df, temp = train_test_split(df, train_size=args.train_size, random_state=args.seed)
    val_df, test_df = train_test_split(temp, train_size=args.val_size, random_state=args.seed)
    print(f"Train: {len(train_df)}, Val: {len(val_df)}, Test: {len(test_df)}")

    collate = create_collate_fn(tw2i["<pad>"], gw2i["<pad>"])
    train_ld = DataLoader(TranslationDataset(train_df), args.batch_size, shuffle=True, collate_fn=collate)
    val_ld = DataLoader(TranslationDataset(val_df), args.batch_size, collate_fn=collate)
    test_ld = DataLoader(TranslationDataset(test_df), args.batch_size, collate_fn=collate)

    model = TransformerModel(len(text_vocab), len(gloss_vocab), args.embedding_dim, args.nhead,
                             args.num_encoder_layers, args.num_decoder_layers, args.dropout,
                             args.max_len, tw2i["<pad>"]).to(device)
    print(f"Parameters: {sum(p.numel() for p in model.parameters()):,}")

    opt = torch.optim.Adam(model.parameters(), lr=0, betas=(0.9, 0.98), eps=1e-9)
    sched = NoamLR(opt, args.embedding_dim, args.warmup_steps, args.lr_factor)
    loss_fn = LabelSmoothing(args.label_smoothing, gw2i["<pad>"])

    cfg = vars(args)
    vocab = {'text_vocab': text_vocab, 'gloss_vocab': gloss_vocab, 'tw2i': tw2i, 'gw2i': gw2i,
             'ti2w': {str(k):v for k,v in ti2w.items()}, 'gi2w': {str(k):v for k,v in gi2w.items()}}

    if args.evaluate_only:
        load_ckpt(args.resume_from or f"{args.checkpoint_dir}/best_model.pt", model)
        eval_bleu_rouge(model, test_ld, tw2i["<pad>"], gw2i["<start>"], gw2i["<end>"], ti2w, gi2w, device)
    else:
        train(model, train_ld, val_ld, opt, sched, loss_fn, device, cfg, args.checkpoint_dir, vocab)
        best = Path(args.checkpoint_dir) / 'best_model.pt'
        if best.exists():
            load_ckpt(best, model)
            print("\n=== Test Evaluation ===")
            eval_bleu_rouge(model, test_ld, tw2i["<pad>"], gw2i["<start>"], gw2i["<end>"], ti2w, gi2w, device)

if __name__ == '__main__':
    main()
